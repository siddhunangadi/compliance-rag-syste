# Application
APP_ENV=development
APP_NAME=Compliance RAG System

# Frontend / Backend
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:8501

# Optional: comma-separated frontend URLs for CORS.
# Example production value:
# ALLOWED_ORIGINS=https://your-streamlit-app.streamlit.app,https://app.example.com
ALLOWED_ORIGINS=http://localhost:8501

# Google Gemini
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_GENERATION_MODEL=gemini-2.5-flash
GEMINI_CHAT_MODEL=gemini-2.5-flash

# Pinecone
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
PINECONE_NAMESPACE=documents

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
